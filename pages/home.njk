---
layout: layouts/base.njk
title: Home
permalink: /
---
<div class="space-y-6">
  <div class="border-b border-slate-700/60 pb-6">
    <div class="flex items-center gap-2 mb-3">
      <span class="px-2 py-0.5 rounded text-[10px] font-black uppercase tracking-wider bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">
        QRV
      </span>
      <span class="text-xs text-slate-400 font-medium tracking-wide">Station Status: Active from Warrington (IO83qk)</span>
    </div>
    <h2 class="text-2xl font-extrabold text-white tracking-tight sm:text-3xl">
      Welcome to my radio exploits
    </h2>
    <p class="mt-3 text-sm text-slate-300 leading-relaxed">
      This is home base for my amateur radio journey—portable ops, antenna experiments, contest memories, and honest gear reviews from the shack and the field.
    </p>
    <div class="mt-4 flex flex-wrap gap-3">
      <a href="/blog/" class="inline-flex items-center justify-center px-4 py-2 text-xs font-bold text-slate-900 bg-sky-400 hover:bg-sky-300 rounded-lg shadow-lg shadow-sky-500/10 transition">
        Read Articles
      </a>
      <a href="/gallery/" class="inline-flex items-center justify-center px-4 py-2 text-xs font-bold text-slate-300 bg-slate-700/50 hover:bg-slate-700 hover:text-white rounded-lg border border-slate-600/50 transition">
        View Gallery
      </a>
    </div>
  </div>

  <div>
    <h3 class="text-xs font-bold uppercase tracking-widest text-sky-400 mb-4 flex items-center gap-2">
      Recent Articles
    </h3>

    <div class="space-y-4">
      {% set postslist = collections.posts %}
      {% for post in postslist | reverse %}
        <article class="p-4 bg-slate-900/40 border border-slate-700/50 hover:border-slate-600 rounded-xl transition shadow-sm group">
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2">
            <div>
              <h4 class="text-sm font-bold text-slate-200 group-hover:text-sky-400 transition">
                <a href="{{ post.url | url }}">{{ post.data.title }}</a>
              </h4>
              <p class="text-xs text-slate-400 mt-1">
                {{ post.data.description or "Click to open this article and read the full details..." }}
              </p>
            </div>
            <time class="text-[11px] font-medium text-slate-500 whitespace-nowrap bg-slate-900 px-2 py-1 rounded border border-slate-800 self-start sm:self-center">
              {{ post.date | readableDate }}
            </time>
          </div>
        </article>
      {% else %}
        <p class="text-xs text-slate-500 italic p-4 bg-slate-900/20 rounded-xl border border-dashed border-slate-800">
          No articles found in the archives directory.
        </p>
      {% endfor %}
    </div>
  </div>
</div>