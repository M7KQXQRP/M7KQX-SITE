---
layout: layouts/main.njk
---
<div class="w-full min-h-screen bg-slate-900 text-slate-100 font-sans antialiased p-4 md:p-6">
  <div class="max-w-6xl mx-auto">
    
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">
      
      <div class="lg:col-span-2 space-y-6">
        
        <div class="w-full bg-gradient-to-r from-slate-950 to-slate-800 border border-slate-700 rounded-xl p-6 shadow-xl relative overflow-hidden">
          <div class="relative z-10">
            <h1 class="text-4xl font-black tracking-wider text-sky-400">M7KQX</h1>
            <p class="text-xs text-slate-400 uppercase tracking-widest mt-1 font-medium">Amateur Radio Station & Project Log</p>
          </div>
          <div class="absolute right-4 bottom-2 opacity-5 text-7xl font-black text-slate-400 select-none pointer-events-none">RADIO</div>
        </div>

        <nav class="bg-slate-800 border border-slate-700 rounded-xl p-2 flex flex-wrap gap-2 text-sm font-semibold shadow-md">
          <a href="/" class="text-sky-400 hover:text-sky-300 px-3 py-2 rounded-lg bg-slate-900/60 transition">Home</a>
          <a href="/category/builds/" class="text-slate-300 hover:text-sky-400 px-3 py-2 rounded-lg hover:bg-slate-700/50 transition">Antenna Builds</a>
          <a href="/category/reviews/" class="text-slate-300 hover:text-sky-400 px-3 py-2 rounded-lg hover:bg-slate-700/50 transition">Equipment Reviews</a>
          <a href="/category/articles/" class="text-slate-300 hover:text-sky-400 px-3 py-2 rounded-lg hover:bg-slate-700/50 transition">Articles</a>
        </nav>

        <div class="bg-slate-800 border border-slate-700 rounded-xl p-5 shadow-xl">
          <h2 class="text-xs font-bold uppercase tracking-widest text-sky-400 mb-4 flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-sky-400"></span>
            Live Station Profile
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-xs">
            <div class="bg-slate-900/60 p-3 rounded-lg border border-slate-700/60">
              <span class="block text-slate-400 uppercase font-medium mb-1">Main Rig</span>
              <span class="font-bold text-slate-200">Xiegu G90 (20W QRP)</span>
            </div>
            <div class="bg-slate-900/60 p-3 rounded-lg border border-slate-700/60">
              <span class="block text-slate-400 uppercase font-medium mb-1">Antenna System</span>
              <span class="font-bold text-slate-200">DIY EFHW (End-Fed Half-Wave)</span>
            </div>
            <div class="bg-slate-900/60 p-3 rounded-lg border border-slate-700/60">
              <span class="block text-slate-400 uppercase font-medium mb-1">Modes of Choice</span>
              <span class="font-bold text-slate-200">FT8 / RTTY / PSK31 / CW</span>
            </div>
          </div>
        </div>

        <main class="bg-slate-800 border border-slate-700 rounded-xl p-6 shadow-xl text-slate-100">
          {{ content | safe }}
        </main>

      </div>

      <div class="space-y-6 lg:sticky lg:top-6">
        
        <div class="bg-slate-800 border border-slate-700 rounded-xl p-4 shadow-xl">
          <h3 class="text-xs font-bold uppercase tracking-widest text-emerald-400 mb-3 flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
            QRZ.com Live Logbook
          </h3>
          
          <div class="w-full flex justify-center">
            
            <div class="w-[310px] bg-slate-950 rounded-lg border border-slate-700 overflow-hidden p-2 shadow-inner">
              
              <iframe 
                src="https://logbook.qrz.com/lbstat/M7KQX/" 
                class="w-[335px] min-h-[360px] rounded border-0 bg-white invert-[0.93] hue-rotate-180 contrast-[1.25] brightness-[0.95]"
                title="M7KQX QRZ Logbook Summary"
                scrolling="no">
              </iframe>

            </div>

          </div>
          
          <p class="text-[10px] text-slate-500 text-center mt-2 italic">
            Dynamically streaming secure station telemetry from QRZ databases.
          </p>
        </div>

      </div>

    </div>
  </div>
</div>