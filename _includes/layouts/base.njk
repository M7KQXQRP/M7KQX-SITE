<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title or metadata.title }}</title>
    <meta name="description" content="{{ description or metadata.description }}">
    
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="bg-slate-950 text-slate-100 min-h-screen font-sans antialiased">
    
    <header class="max-w-6xl mx-auto pt-4 px-4">
<img src="/static/img/website-banner-cropped.png" alt="M7KQX Radio Banner" class="w-full h-auto object-cover">
      </div>

      <nav class="bg-slate-900 border-x border-b border-slate-800 rounded-b-xl px-6 py-4 flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <div class="bg-slate-800 p-2 rounded-lg border border-slate-700 hidden sm:block">
            📻
          </div>
          <div>
            <a href="/" class="text-xl font-black tracking-wider text-slate-100 block">M7KQX</a>
            <span class="text-xs tracking-widest text-cyan-400 font-mono font-bold block uppercase">Amateur Radio</span>
          </div>
        </div>
        
        <ul class="flex items-center gap-6 text-sm font-medium text-slate-400">
          <li><a href="/" class="hover:text-cyan-400 transition text-slate-200">Home</a></li>
          <li><a href="/posts/" class="hover:text-cyan-400 transition">Logbook & Reviews</a></li>
          <li><a href="/gallery/" class="hover:text-cyan-400 transition">Gallery</a></li>
          <li><a href="/about/" class="hover:text-cyan-400 transition">Contact</a></li>
        </ul>
      </nav>
    </header>

    <main class="max-w-6xl mx-auto px-4 py-8">
      {{ content | safe }}
    </main>

    <footer class="max-w-6xl mx-auto px-4 py-8 mt-12 border-t border-slate-900 text-center text-xs text-slate-600 font-mono">
      © 2026 Christopher Webster (M7KQX). All rights reserved.
    </footer>
  </body>
</html>